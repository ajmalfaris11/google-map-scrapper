generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id           String       @id @default(uuid())
  keyword      String
  location     String?
  provider     String
  status       String       @default("RUNNING")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  businesses   Business[]
  checkpoints  Checkpoint[]
}

model Business {
  id            String   @id @default(uuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  provider      String
  keyword       String
  name          String
  address       String?
  phone         String?
  website       String?
  category      String?
  rating        Float?
  reviewCount   Int?
  latitude      Float?
  longitude     Float?
  openingHours  String?
  googleMapsUrl String?  @unique
  placeId       String?  @unique
  status        String   @default("ACTIVE")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([provider, googleMapsUrl])
  @@index([jobId])
}

model Checkpoint {
  id               String   @id @default(uuid())
  jobId            String
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  lastProcessedUrl String?
  processedCount   Int      @default(0)
  failedCount      Int      @default(0)
  remainingCount   Int      @default(0)
  queueSnapshot    Json?
  workerSnapshot   Json?
  
  createdAt        DateTime @default(now())
  
  @@index([jobId])
}
